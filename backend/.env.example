NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://localhost:5173
MONGODB_URI=mongodb://127.0.0.1:27017/contasolutions
JWT_SECRET=change_this_super_secret_key
JWT_EXPIRES_IN=1d
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES=30
LOG_LEVEL=info
RATE_LIMIT_GLOBAL_MAX=300
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_COMPANIES_MAX=120
RATE_LIMIT_TASKS_MAX=180
RATE_LIMIT_REPORTS_MAX=60
RATE_LIMIT_DASHBOARD_MAX=120
INTERNAL_SCHEDULER_ENABLED=true
ALERTS_CRON=*/30 * * * *
OVERDUE_SYNC_CRON=0 1 * * *
SEED_SUPER_ADMIN_NAME=Super Admin
SEED_SUPER_ADMIN_EMAIL=admin@contasolutions.com
SEED_SUPER_ADMIN_PASSWORD=ContaSolutions123*
